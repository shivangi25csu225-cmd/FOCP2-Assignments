#include <iostream>
using namespace std;

class Course {
    string courseName;
    string instructor;
    int duration;

public:
    // Constructor
    Course(string c, string i, int d) {
        courseName = c;
        instructor = i;
        duration = d;
    }

    // Display function
    void display() {
        cout << "Course Name: " << courseName << endl;
        cout << "Instructor: " << instructor << endl;
        cout << "Duration (weeks): " << duration << endl;
    }

    // Destructor
    ~Course() {
        cout << "Course removed: " << courseName << endl;
    }
};

int main() {
    Course c1("C++ Programming", "Rahul Sir", 6);
    Course c2("Data Structures", "Anita Ma'am", 8);

    c1.display();
    cout << endl;
    c2.display();

    return 0;
}
