#include <iostream>
using namespace std;

// Circle
float area(float r) {
    return 3.14 * r * r;
}

// Rectangle
float area(float l, float b) {
    return l * b;
}

// Triangle
float area(float base, float height, int) {
    return 0.5 * base * height;
}

int main() {
    int choice;
    float x, y;

    cout << "1.Circle 2.Rectangle 3.Triangle\n";
    cout << "Enter choice: ";
    cin >> choice;

    if(choice == 1) {
        cout << "Enter radius: ";
        cin >> x;
        cout << "Area = " << area(x);
    }
    else if(choice == 2) {
        cout << "Enter length and breadth: ";
        cin >> x >> y;
        cout << "Area = " << area(x, y);
    }
    else if(choice == 3) {
        cout << "Enter base and height: ";
        cin >> x >> y;
        cout << "Area = " << area(x, y, 1);
    }
    else {
        cout << "Invalid choice";
    }

    return 0;
}
