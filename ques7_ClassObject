#include <iostream>
using namespace std;

class Table {
    string material;
    float price;
    int legs;

public:
    // 1. Default constructor
    Table() {
        material = "Wood";
        price = 5000;
        legs = 4;
    }

    // 2. Constructor with material and price
    Table(string m, float p) {
        material = m;
        price = p;
        legs = 4;   // default legs
    }

    // 3. Constructor with material, price, and legs
    Table(string m, float p, int l) {
        material = m;
        price = p;
        legs = l;
    }

    // Display function
    void display() {
        cout << "Material: " << material << endl;
        cout << "Price: " << price << endl;
        cout << "Legs: " << legs << endl;
        cout << endl;
    }
};

int main() {
    Table t1;                       // default constructor
    Table t2("Steel", 7000);        // material + price
    Table t3("Plastic", 3000, 3);   // material + price + legs

    cout << "Table 1:\n";
    t1.display();

    cout << "Table 2:\n";
    t2.display();

    cout << "Table 3:\n";
    t3.display();

    return 0;
}
