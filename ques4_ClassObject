#include <iostream>
using namespace std;

class Employee {
    int emp_id;
    float salary;

public:
    // Parameterized constructor
    Employee(int id, float sal) {
        emp_id = id;
        salary = sal;
    }

    // Function to display employee details
    void display() {
        cout << "Employee ID: " << emp_id << endl;
        cout << "Salary: " << salary << endl;
    }
};

int main() {
    Employee e1(101, 50000);   // object created

    e1.display();

    return 0;
}
