#include <iostream>
using namespace std;

int main() {
    int n, num, max;

    cout << "Enter how many numbers: ";
    cin >> n;

    cout << "Enter number: ";
    cin >> max;

    for(int i = 2; i <= n; i++) {
        cout << "Enter number: ";
        cin >> num;

        if(num > max)
            max = num;
    }

    cout << "Largest number = " << max;

    return 0;
}
