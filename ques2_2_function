#include<iostream>
using namespace std;

void swapByValue(int a, int b)
{
    int temp;
    temp = a;
    a = b;
    b = temp;
}

int main()
{
    int a, b;

    cout << "Enter value of a" << endl;
    cin >> a;

    cout << "Enter value of b" << endl;
    cin >> b;

    cout << "Before swap: a is " << a << " and b is " << b << endl;

    swapByValue(a, b);

    cout << "After swap: a is " << a << " and b is " << b << endl;

    return 0;
}
