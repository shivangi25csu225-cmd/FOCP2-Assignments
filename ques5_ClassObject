#include <iostream>
using namespace std;

class Book {
    string title;
    float price;

public:
    // Constructor
    Book(string t, float p) {
        title = t;
        price = p;
    }

    // Function to display details
    void display() {
        cout << "Title: " << title << endl;
        cout << "Price: " << price << endl;
    }
};

int main() {
    Book b1("C++ Basics", 500);
    Book b2("Data Structures", 750);

    cout << "Book 1 Details:" << endl;
    b1.display();

    cout << "\nBook 2 Details:" << endl;
    b2.display();

    return 0;
}
